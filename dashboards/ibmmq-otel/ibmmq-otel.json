          "visualization": {
            "id": "viz.area"
          },
          "rawConfiguration": {
            "dataFormatters": [],
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT latest(ibmmq_qmgr_connection_count) AS 'Connections' FROM Metric WHERE instrumentation.provider = 'opentelemetry' FACET qmgr TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Errors",
          "layout": {
