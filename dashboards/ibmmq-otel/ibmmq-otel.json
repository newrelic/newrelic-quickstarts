                "accountId": 0,
                "query": "SELECT uniqueCount(qmgr) AS 'Queue Managers' FROM Metric WHERE instrumentation.provider = 'opentelemetry' AND metricName LIKE 'ibmmq_qmgr_%' LIMIT MAX"
              }
