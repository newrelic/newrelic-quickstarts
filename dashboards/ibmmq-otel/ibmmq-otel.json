                "query": "SELECT latest(ibmmq.queue.input_handles) AS 'Input', latest(ibmmq.queue.output_handles) AS 'Output', latest(ibmmq.queue.publish.handles) AS 'Publish', latest(ibmmq.queue.browse.handles) AS 'Browse' FROM Metric FACET ibmmq.queue TIMESERIES AUTO LIMIT MAX"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        }
      ]
    }
  ]
}
