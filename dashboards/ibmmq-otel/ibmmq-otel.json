            "id": "viz.area"
          },
          "rawConfiguration": {
            "dataFormatters": [],
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT latest(ibmmq.qmgr.connection_count) AS 'Connections' FROM Metric FACET ibmmq.queue_manager TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Errors",
          "layout": {
            "column": 9,
            "row": 1,
            "width": 4,
            "height": 6
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.stacked-bar"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT rate(sum(ibmmq.qmgr.failed.mqopen.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.mqclose.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.mqinq.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.mqset.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.mqcb.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.mqget.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.mqput.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.mqput1.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.mqsubrq.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.mqconn.mqconnx.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.browse.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.create.alter.resume.subscription.count), 1 minute) + rate(sum(ibmmq.qmgr.failed.topic.mqput.count), 1 minute) AS 'Errors/min' FROM Metric TIMESERIES AUTO FACET ibmmq.queue_manager"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "",
