              {
                "accountId": 0,
                "query": "SELECT latest(ibmmq.queue.depth) AS 'Depth', latest(ibmmq.queue.depth) * 100 / latest(ibmmq.queue.attribute.max.depth) AS 'Depth %', rate(sum(ibmmq.queue.mqput.count), 1 minute) + rate(sum(ibmmq.queue.mqput1.persistent.message.count), 1 minute) + rate(sum(ibmmq.queue.mqput1.non.persistent.message.count), 1 minute) AS 'Put/min', rate(sum(ibmmq.queue.mqget.count), 1 minute) AS 'Get/min', sum(ibmmq.queue.expired.messages) AS 'Expired' FROM Metric FACET ibmmq.queue_manager, ibmmq.queue LIMIT MAX"
              }
            ]
          }
        },
