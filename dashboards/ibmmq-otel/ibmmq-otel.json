            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(ibmmq_qmgr_failed_browse_count) + average(ibmmq_qmgr_failed_mqcb_count) + average(ibmmq_qmgr_failed_mqclose_count) + average(ibmmq_qmgr_failed_mqconn_mqconnx_count) + average(ibmmq_qmgr_failed_mqget_count) + average(ibmmq_qmgr_failed_mqinq_count) + average(ibmmq_qmgr_failed_mqopen_count) + average(ibmmq_qmgr_failed_mqput1_count) + average(ibmmq_qmgr_failed_mqput_count) + average(ibmmq_qmgr_failed_mqset_count) + average(ibmmq_qmgr_failed_mqsubrq_count) + average(ibmmq_qmgr_failed_create_alter_resume_subscription_count) + average(ibmmq_qmgr_failed_topic_mqput_mqput1_count) AS 'Errors' FROM Metric WHERE instrumentation.provider = 'opentelemetry' TIMESERIES AUTO FACET qmgr"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "",
