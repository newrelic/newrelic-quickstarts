              {
                "accountId": 0,
                "query": "SELECT filter(count(*), WHERE status = 2) AS 'Active', filter(count(*), WHERE status != 2) AS 'Inactive' FROM (SELECT latest(ibmmq_qmgr_status) AS status FROM Metric WHERE instrumentation.provider = 'opentelemetry' FACET qmgr)"
              }
            ],
            "thresholds": [
