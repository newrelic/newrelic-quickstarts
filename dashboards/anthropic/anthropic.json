          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT percentile(duration.ms, 99) as 'P99 Duration (ms)' FROM Span WHERE llm.model IS NOT NULL AND instrumentation.provider = 'opentelemetry' SINCE 1 hour ago COMPARE WITH 1 hour ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "thresholds": []
