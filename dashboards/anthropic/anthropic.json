        {
          "title": "Cost",
          "layout": {
            "column": 9,
            "row": 5,
            "width": 2,
            "height": 2
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT (sum(llm.usage.input_tokens) * 0.15 / 1000000) + (sum(llm.usage.output_tokens) * 0.60 / 1000000) as 'Cost ($)' FROM Span WHERE llm.model IS NOT NULL AND instrumentation.provider = 'opentelemetry' SINCE 1 hour ago COMPARE WITH 1 hour ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "title": "Success Rate",
          "layout": {
            "column": 11,
            "row": 5,
            "width": 2,
            "height": 2
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT percentage(count(*), WHERE otel.status_code = 'OK') as 'Success %' FROM Span WHERE llm.model IS NOT NULL AND instrumentation.provider = 'opentelemetry' SINCE 1 hour ago COMPARE WITH 1 hour ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "thresholds": [
              {
                "alertSeverity": "WARNING",
                "value": 101
              },
              {
                "alertSeverity": "CRITICAL",
                "value": 102
              }
            ]
          }
        },
        {
          "title": "Time To First Token",
          "layout": {
            "column": 1,
            "row": 7,
            "width": 3,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(llm.time_to_first_token) as 'Avg TTFT (ms)', percentile(llm.time_to_first_token, 50) as 'P50 (ms)', percentile(llm.time_to_first_token, 95) as 'P95 (ms)' FROM Span WHERE llm.model IS NOT NULL AND instrumentation.provider = 'opentelemetry' AND llm.time_to_first_token IS NOT NULL SINCE 1 hour ago COMPARE WITH 1 hour ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "thresholds": []
          }
        },
        {
