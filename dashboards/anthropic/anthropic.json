{
  "name": "LLM and AI Observability",
  "description": "Monitor Anthropic Claude API usage — cost, tokens, latency, and error rates across models.",
  "pages": [
    {
      "name": "Service Health & Performance",
      "description": null,
      "widgets": [
        {
          "title": "",
          "layout": {
            "column": 1,
