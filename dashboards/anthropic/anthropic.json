            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "![Anthropic logo](https://raw.githubusercontent.com/newrelic/newrelic-quickstarts/main/quickstarts/anthropic/logo.png)\n\nMonitor your Anthropic Claude models (Haiku, Sonnet & Opus) in real time using **OpenLLMetry** — an OpenTelemetry-based instrumentation for LLMs.\n\n- Cost & token usage per model\n- Latency, TTFT & error rates\n- End-to-end request tracing"
          }
        },
        {
          "title": "AI Requests Total per AI Model",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 8,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.area"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) as 'Requests' FROM Span WHERE llm.model IS NOT NULL AND instrumentation.provider = 'opentelemetry' FACET llm.model TIMESERIES AUTO SINCE 1 hour ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "title": "",
          "layout": {
