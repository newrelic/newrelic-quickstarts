            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT rate(sum(llm.usage.total_tokens), 1 second) as 'Tokens/sec' FROM Span WHERE llm.model IS NOT NULL AND instrumentation.provider = 'opentelemetry' SINCE 1 hour ago COMPARE WITH 1 hour ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
