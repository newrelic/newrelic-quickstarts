              {
                "accountIds": [],
                "query": "SELECT average(duration.ms) as 'Avg Duration (ms)' FROM Span WHERE llm.model IS NOT NULL AND instrumentation.provider = 'opentelemetry' SINCE 1 hour ago COMPARE WITH 1 hour ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "thresholds": []
