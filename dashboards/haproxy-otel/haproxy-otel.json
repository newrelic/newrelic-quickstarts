            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT sum(haproxy.connections.retries) AS 'Retries' WHERE instrumentation.provider = 'opentelemetry' AND haproxy.service_name NOT IN ('FRONTEND', 'BACKEND') AND haproxy.proxy_name IN ({{proxy_name}}) FACET haproxy.service_name TIMESERIES"
              }
