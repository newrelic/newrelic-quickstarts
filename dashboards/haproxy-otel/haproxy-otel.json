            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT rate(sum(haproxy.bytes.input), 1 second) AS 'Bytes In/sec', rate(sum(haproxy.bytes.output), 1 second) AS 'Bytes Out/sec', latest(haproxy.requests.rate) AS 'Requests/sec' WHERE instrumentation.provider = 'opentelemetry' AND haproxy.service_name NOT IN ('FRONTEND', 'BACKEND') AND haproxy.proxy_name IN ({{proxy_name}}) FACET haproxy.proxy_name, haproxy.service_name"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
