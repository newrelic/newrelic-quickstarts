            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT sum(haproxy.requests.denied) AS 'Requests Denied', sum(haproxy.responses.denied) AS 'Responses Denied' WHERE instrumentation.provider = 'opentelemetry' AND haproxy.proxy_name IN ({{proxy_name}}) TIMESERIES"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Backend Server Health",
          "layout": {
            "column": 7,
            "row": 27,
            "width": 6,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT latest(haproxy.sessions.count) AS 'Active Sessions', sum(haproxy.server_selected.total) AS 'Times Selected', sum(haproxy.connections.retries) AS 'Retries', sum(haproxy.requests.redispatched) AS 'Redispatches' WHERE instrumentation.provider = 'opentelemetry' AND haproxy.service_name NOT IN ('FRONTEND', 'BACKEND') AND haproxy.proxy_name IN ({{proxy_name}}) FACET haproxy.proxy_name, haproxy.service_name"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "title": "Network I/O by Backend Server",
          "layout": {
            "column": 1,
            "row": 30,
            "width": 6,
            "height": 3
          },
          "linkedEntityGuids": null,
