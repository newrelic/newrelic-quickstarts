                "relatedDeployments": true,
                "warningViolations": false
              }
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  6729598
                ],
                "query": "SELECT \n  filter(sum(`claude_code.token.usage`), where type = 'input') as 'Input Tokens',\n  filter(sum(`claude_code.token.usage`), where type = 'output') as 'Output Tokens',\n  filter(sum(`claude_code.token.usage`), where type in('cacheCreation','cacheRead')) as 'Cache Tokens',\n  sum(`claude_code.token.usage`) as 'Total Tokens'\nFROM Metric\nWHERE metricName = 'claude_code.token.usage'\nTIMESERIES\nSince 2 days ago"
              }
            ],
