          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "# About This Page\nYou may notice a discrepancy between the percentages on the widgets on this dashboard. The widget above uses `uniqueCount()` and so it is an approximation, and may not match the data displayed by the other widgets.\n\nThe chart on the top right shows in aggregate how many CCUs each cohort are consuming per month, i.e. if you add up the consumption of all users who are consuming 100-999 CCUs per month, this shows how many CCUs that group are consuming in total."
          }
        },
        {
          "title": "Number of Users by CCU Cohort",
          "layout": {
            "column": 1,
            "row": 3,
            "width": 6,
            "height": 4
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.pie"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": true
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM NrConsumption JOIN\n(\n  FROM NrConsumption\n  SELECT sum(consumption) AS totalConsumption\n  WHERE metric = 'CoreCCU'\n   AND (dimension_email IS NOT NULL OR dimension_apiKeyId IS NOT NULL)\n  FACET dimension_email\n  SINCE 1 month ago\n  LIMIT max\n)\n\nON dimension_email\n\nSELECT uniqueCount(dimension_email) AS 'Users' FACET CASES (\n WHERE totalConsumption >= 0 AND totalConsumption <10 AS '1-9 CCUs per month',\n WHERE totalConsumption >= 10 AND totalConsumption <100 AS '10-99 CCUs per month',\n WHERE totalConsumption >= 100 AND totalConsumption <1000 AS '100-999 CCUs per month',\n WHERE totalConsumption >= 1000 AS '1000+ CCUs per month'\n)\n\nSINCE 1 month ago\nLIMIT max"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "title": "Total CCU Consumption by CCU Cohort",
          "layout": {
