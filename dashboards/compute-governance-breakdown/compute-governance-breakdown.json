            "id": "viz.pie"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": true
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM NrConsumption JOIN (\n  FROM NrConsumption\n  SELECT sum(consumption) AS totalConsumption\n  WHERE metric = 'CoreCCU'\n   AND (dimension_email IS NOT NULL OR dimension_apiKeyId IS NOT NULL)\n  FACET dimension_email\n  SINCE 1 month ago\n  LIMIT max\n)\n\nON dimension_email\n\nSELECT sum(consumption) AS 'Total CCUs consumed by cohort' FACET CASES (\n WHERE totalConsumption >= 0 AND totalConsumption <10 AS '1-9 CCUs per month',\n WHERE totalConsumption >= 10 AND totalConsumption <100 AS '10-99 CCUs per month',\n WHERE totalConsumption >= 100 AND totalConsumption <1000 AS '100-999 CCUs per month',\n WHERE totalConsumption >= 1000 AS '1000+ CCUs per month'\n)\n\nWHERE metric = 'CoreCCU'\n AND (dimension_email IS NOT NULL OR dimension_apiKeyId IS NOT NULL)\n AND (timestamp <= 1760950800000 OR timestamp >= 1760958000000)\nSINCE 1 month ago\nLIMIT max"
              }
            ],
