            "text": "# Query Analysis"
          }
        },
        {
          "title": "CCU Usage By Query",
          "layout": {
            "column": 1,
            "row": 2,
            "width": 12,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM NrComputeUsage \nSELECT sum(usage) AS 'CCUs', \n count(*), \n sum(usage)/count(*) as 'CCU/count', \n average((dimension_untilTime - dimension_sinceTime) / (1000 * 3600 * 24)) as 'Time Window (days)'\nWHERE metric = 'CoreCCU' \n AND dimension_query IS NOT NULL\n AND dimension_email IS NOT NULL\n AND dimension_productCapability != 'Dashboards'  \nFACET dimension_query as 'Query', dimension_email as 'User Email', dimension_productCapability as 'Capability'\nSINCE 1 month ago \nLIMIT 1000"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": true
            }
          }
        },
        {
          "title": "Query Efficiency (executions)",
          "layout": {
            "column": 1,
            "row": 5,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.pie"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": true
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM NrComputeUsage\nSELECT count(*) AS 'Executions'\nWHERE metric = 'CoreCCU' AND dimension_query IS NOT NULL\n AND dimension_email IS NOT NULL\nSINCE 1 month ago \nFACET CASES (\n WHERE usage > 1 as 'Inefficient (>1 CCU per Execution)', \n WHERE usage <= 1 as 'Efficient (<=1 CCU per Execution)'\n)\nLIMIT MAX"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "title": "Query Efficiency (CCUs)",
