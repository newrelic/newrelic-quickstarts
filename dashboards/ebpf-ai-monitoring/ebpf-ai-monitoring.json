{
  "name": "eBPF - AI Monitoring",
  "description": null,
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "Summary",
      "description": null,
      "widgets": [
        {
          "title": "AI Models used",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 12,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "\nSELECT\n   sum(gen_ai.client.request.count) AS 'Requests',\n   filter(average(gen_ai.client.token.usage), WHERE gen_ai.token.type='input') as 'Average input tokens (prompt)',\n   filter(average(gen_ai.client.token.usage), WHERE gen_ai.token.type='output') as 'Average output tokens (completion)',\n   filter(percentage(count(gen_ai.client.operation.duration), WHERE error.type != '' AND error.type IS NOT NULL), WHERE entity.name IN ({{entity_name}})) AS 'Error rate(%)',\n   round(average(gen_ai.client.operation.duration) / (1000*1000*1000), 0.001) as 'Average response time (s)'\nFROM Metric\nWHERE entity.name IN ({{entity_name}}) \nFACET entity.name AS 'Entity name', gen_ai.system AS 'Provider', gen_ai.request.model AS 'Model' LIMIT MAX"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "refreshRate": {
              "frequency": 30000
            },
            "thresholds": [
              {
                "columnName": "Error rate(%)",
                "from": 0,
                "severity": "unavailable",
                "to": 0
              },
              {
                "columnName": "Error rate(%)",
                "from": 0.01,
                "severity": "warning",
                "to": 0.1
              },
              {
                "columnName": "Error rate(%)",
                "from": 0.11,
                "severity": "severe",
                "to": 0.5
              },
              {
                "columnName": "Error rate(%)",
                "from": 0.51,
                "severity": "critical",
                "to": 1
              }
            ]
          }
        },
        {
          "title": "Total AI requests",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": [],
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "chartStyles": {
              "lineInterpolation": "smooth"
            },
            "facet": {
              "showOtherSeries": false
            },
            "linkedEntityGuids": [],
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT sum(gen_ai.client.request.count) as Requests WHERE entity.name IN ({{entity_name}}) AND ai.enabled=true FACET entity.name LIMIT MAX COMPARE WITH 30 minutes ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "refreshRate": {
              "frequency": 30000
            }
          }
        },
        {
          "title": "Average response time (s)",
          "layout": {
            "column": 5,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "chartStyles": {
              "lineInterpolation": "smooth"
            },
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT\n  average(gen_ai.client.operation.duration)/(1000*1000*1000)\nWHERE entity.name IN ({{entity_name}}) AND metricName='gen_ai.client.operation.duration' FACET entity.name LIMIT MAX "
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "refreshRate": {
              "frequency": 30000
            }
          }
        },
        {
          "title": "Error rate",
          "layout": {
            "column": 9,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "chartStyles": {
              "lineInterpolation": "smooth"
            },
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT percentage(count(*), WHERE metricName='gen_ai.client.operation.duration' AND error.type != '' AND error.type IS NOT NULL) AS 'Error rate' WHERE metricName='gen_ai.client.operation.duration' AND entity.name IN ({{entity_name}}) COMPARE WITH 30 minutes ago FACET gen_ai.system, entity.name EXTRAPOLATE LIMIT MAX "
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "refreshRate": {
              "frequency": 30000
            }
          }
        }
      ]
