        {
          "id": "100504672",
          "title": "Connections",
          "layout": {
            "column": 1,
            "row": 5,
            "width": 12,
            "height": 4
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT\n sum(ebpf.tcp.connection.open) AS 'Connection Opened',\n sum(ebpf.tcp.connection.close) AS 'Connection Closed' where entity.name IN ({{entity_name}}) and instrumentation.name='nr_ebpf' and concat({{filter_variable}}) IN ({{filter_values}}) and protocol.name='tcp' and tcp_established!='NA' FACET concat({{filter_variable}}) AS 'Filter by', local_addr,\n remote_addr, tcp_established, direction\n  LIMIT MAX"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        }
      ]
