        {
          "id": "100504669",
          "title": "DNS Errors",
          "layout": {
            "column": 5,
            "row": 4,
            "width": 8,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Span SELECT \n      count(*) AS 'Error count',\n      latest(local_addr) AS 'Local address', latest(remote_addr) AS 'Remote address', latest(remote.host.name) AS 'Remote host name'\n       WHERE entity.name IN ({{entity_name}}) AND instrumentation.name='nr_ebpf' AND concat({{filter_variable}}) IN ({{filter_values}}) AND protocol.name = 'dns' AND concat({{filter_variable}}) != '' AND dns.query != '' AND dns.query != '[]' AND dns.query IS NOT NULL AND dns.resolved = false FACET concat({{filter_variable}}) AS 'Filter', dns.query AS 'DNS query', dns.rcode_name AS 'RCODE'\n       LIMIT MAX"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "id": "100504667",
          "title": "HTTP Errors",
          "layout": {
            "column": 1,
            "row": 7,
            "width": 12,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Span SELECT \n      count(*) AS 'Error count',\n      latest(error.group.name) AS 'HTTP route', latest(local_addr) AS 'Local addr', latest(local_port) AS 'Local port',\n      latest(remote.host.name) AS 'Remote host name',\n      \n      latest(remote_addr) AS 'Remote addr',\n      latest(remote_port) AS 'Remote port',\n      latest(http.host) AS 'HTTP host' WHERE error.group.guid IS NOT NULL AND entity.name IN ({{entity_name}}) AND instrumentation.name='nr_ebpf' AND concat({{filter_variable}}) IN ({{filter_values}}) FACET concat({{filter_variable}}) AS 'Filter', error.group.message\n      LIMIT MAX"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "id": "100504668",
          "title": "TCP Errors",
          "layout": {
            "column": 1,
            "row": 10,
            "width": 12,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT\n      sum(ebpf.tcp.connection.error) AS 'Error count', latest(local_addr) AS 'Local address', latest(local_port) AS 'Local port', latest(direction) AS 'Direction', latest(remote_addr) AS 'Remote address', latest(remote.host.name) AS 'Remote host name'\n       WHERE entity.name IN ({{entity_name}}) AND instrumentation.name='nr_ebpf' AND concat({{filter_variable}}) IN ({{filter_values}}) AND protocol.name = 'tcp' AND metricName = 'ebpf.tcp.connection.error' AND error != '' AND error IS NOT NULL FACET concat({{filter_variable}}) AS 'Filter',\nerror as 'Error message'\n      LIMIT MAX"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        }
      ]
    },
