        {
          "id": "100504671",
          "title": "Connection throughput",
          "layout": {
            "column": 7,
            "row": 1,
            "width": 6,
            "height": 4
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "chartStyles": {
              "lineInterpolation": "linear"
            },
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "markers": {
              "displayedTypes": {
                "annotations": true,
                "criticalViolations": false,
                "deployments": true,
                "relatedDeployments": true,
                "warningViolations": false
              }
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric \n      SELECT sum(ebpf.tcp.rx) + sum(ebpf.tcp.tx) AS 'Throughput'\n      WHERE entity.name IN ({{entity_name}}) AND instrumentation.name='nr_ebpf' AND concat({{filter_variable}}) IN ({{filter_values}}) AND\n      protocol.name = 'tcp' AND tcp_established != 'NA' AND metricName IN ('ebpf.tcp.tx','ebpf.tcp.rx')\n      FACET concat({{filter_variable}}) LIMIT MAX TIMESERIES "
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "thresholds": {
              "isLabelVisible": true
            },
