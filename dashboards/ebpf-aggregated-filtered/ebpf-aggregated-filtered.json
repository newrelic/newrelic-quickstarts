    {
      "name": "TCP flags",
      "description": null,
      "widgets": [
        {
          "id": "100504678",
          "title": null,
          "layout": {
            "column": 1,
            "row": 1,
            "width": 12,
            "height": 5
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric \n    SELECT\n      latest(upper(aparse(metricName, 'ebpf.tcp.*'))) AS 'TCP flags',\n      latest(local_addr) AS 'Local addr',\n      latest(local_port) AS 'Local port',\n      latest(remote.host.name) AS 'Remote host name',\n      latest(remote_addr) AS 'Remote addr'\n    WHERE \n      entity.name IN ({{entity_name}}) AND instrumentation.name='nr_ebpf' AND concat({{filter_variable}}) IN ({{filter_values}}) AND\n      protocol.name = 'tcp' \n      AND type != 'NA'\n      FACET {{filter_variable}} AS 'Filter',\n        upper(aparse(metricName, 'ebpf.tcp.*')) AS 'Flag', \n        direction\n      LIMIT MAX "
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        }
      ]
    },
