                "deployments": true,
                "relatedDeployments": true,
                "warningViolations": false
              }
            },
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Span SELECT  count(*) AS 'DNS Errors' WHERE entity.name IN ({{entity_name}}) AND instrumentation.name='nr_ebpf' AND concat({{filter_variable}}) IN ({{filter_values}}) AND protocol.name = 'dns' AND concat({{filter_variable}}) != '' AND dns.query != '' AND dns.query != '[]' AND dns.query IS NOT NULL AND dns.resolved = false FACET concat({{filter_variable}}), dns.query, dns.rcode_name TIMESERIES  LIMIT MAX"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "thresholds": {
